{
  "expo": {
    "name": "NadaRuns Driver",
    "slug": "nadaruns-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nadaruns",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*",
      "node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/*"
    ],
    "splash": {
      "image": "./assets/images/splash-image.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nadaruns.driver",
      "infoPlist": {
        "NSCameraUsageDescription": "Take delivery proof photos at dropoff",
        "NSPhotoLibraryUsageDescription": "Attach proof photos to deliveries",
        "NSLocationWhenInUseUsageDescription": "Navigate to pickup and dropoff locations",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Track deliveries in background"
      },
      "config": {
        "googleMapsApiKey": "AIzaSyCm_A2yMaW6HF-PTFnu-AuSvkWLCJMHtyM"
      }
    },
    "android": {
      "package": "com.nadaruns.driver",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCm_A2yMaW6HF-PTFnu-AuSvkWLCJMHtyM"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Track deliveries in background",
          "locationAlwaysPermission": "Track deliveries when app is closed",
          "locationWhenInUsePermission": "Navigate to pickup and dropoff locations"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://api.nadaruns.com",
      "adminUrl": "https://admin.nadaruns.com",
      "websiteUrl": "https://nadaruns.com",
      "backendUrl": "https://api.nadaruns.com",
      "eas": {
        "projectId": "bbac3d10-9911-44ff-9079-8a6e544f7f45"
      }
    }
  }
}
